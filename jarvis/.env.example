# Jarvis AI Executive Configuration
# Copy this file to .env and customize as needed

# =============================================================================
# Version
# =============================================================================
JARVIS_VERSION=1.0.0

# =============================================================================
# Environment
# =============================================================================
NODE_ENV=development

# =============================================================================
# Service Ports (from AI Service Port Registry)
# =============================================================================
JARVIS_CORE_PORT=3010
JARVIS_DESKTOP_PORT=3011
JARVIS_MEMORY_PORT=3012
JARVIS_MONITOR_PORT=3015

# =============================================================================
# Mission Control Integration. Reads + task CREATION (owner-approved
# 2026-07-09); every create is decided by the Approval Engine first
# (Constitution Art. V). Update/delete of MC tasks stays out of scope.
# =============================================================================
MISSION_CONTROL_URL=http://localhost:3002
MISSION_CONTROL_API_KEY=
# MC agent that Kiaros-created tasks are assigned to. Default 'main'
# (Constitution Art. II: MC dispatches to OpenClaw `main` only). Set empty
# to leave Kiaros tasks unassigned in the MC inbox.
KIAROS_MC_ASSIGNEE=main

# =============================================================================
# Core API auth (optional). Empty = open on localhost (default). When set,
# /api/v1/* requires it (Authorization: Bearer or x-kiaros-token) and /ws
# requires ?token=. Give the Desktop the same value via VITE_KIAROS_CORE_TOKEN.
# =============================================================================
KIAROS_CORE_TOKEN=

# =============================================================================
# OpenClaw Integration
# =============================================================================
OPENCLAW_GATEWAY_URL=http://localhost:18789

# =============================================================================
# Feature Flags
# =============================================================================
FEATURE_FACE_MODE=true
FEATURE_ORB_MODE=true
FEATURE_SPHERE_MODE=true
FEATURE_WAVE_MODE=true
FEATURE_HUD_MODE=true
FEATURE_AMBIENT_MODE=true

# =============================================================================
# Conversation Intelligence (LLM) — Phase 5
# Kiaros is model-agnostic: the provider is selected here, never in code.
#   auto (default)     = anthropic if ANTHROPIC_API_KEY set, else
#                        openai-compatible if configured, else none
#   anthropic          = Anthropic API (conversation text leaves the machine)
#   openai-compatible  = any /v1/chat/completions runtime: Ollama, LM Studio,
#                        llama.cpp, vLLM, OpenAI, ... (localhost = fully local)
#   none               = built-in template responses only
# =============================================================================
KIAROS_LLM_PROVIDER=auto
# Generic model override (falls back to each provider's default)
KIAROS_LLM_MODEL=
KIAROS_LLM_MAX_TOKENS=1024
KIAROS_LLM_TIMEOUT_MS=30000

# Anthropic provider (default model: claude-opus-4-8)
ANTHROPIC_API_KEY=

# OpenAI-compatible provider (example: Ollama)
# OPENAI_COMPAT_BASE_URL=http://localhost:11434/v1
# OPENAI_COMPAT_MODEL=granite4.1:3b
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=

# =============================================================================
# Cloud Voice Providers (optional). Keys stay in this file and are used only
# by Kiaros Core — the Desktop reaches the providers through Core proxy
# endpoints (/api/v1/voice/*, /ws/voice/stt) and never sees a key.
# Unset = unavailable; the Desktop falls back to the browser Web Speech API.
# NOTE: with a key set, voice audio leaves this machine for the configured
# provider (opt-in exception to the local-only voice invariant).
# =============================================================================
# Deepgram speech-to-text (https://console.deepgram.com)
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2

# ElevenLabs text-to-speech (https://elevenlabs.io)
ELEVENLABS_API_KEY=
# Kiaros's voice. Default: bIHbv24MWmeRgasZH58o
ELEVENLABS_VOICE_ID=bIHbv24MWmeRgasZH58o
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=info

# =============================================================================
# Memory
# =============================================================================
MEMORY_PATH=./memory
MEMORY_RETENTION_DAYS=30
