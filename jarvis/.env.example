# Jarvis AI Executive Configuration
# Copy this file to .env and customize as needed

# =============================================================================
# Version
# =============================================================================
JARVIS_VERSION=1.0.0

# =============================================================================
# Environment
# =============================================================================
NODE_ENV=development

# =============================================================================
# Service Ports (from AI Service Port Registry)
# =============================================================================
JARVIS_CORE_PORT=3010
JARVIS_DESKTOP_PORT=3011
JARVIS_MEMORY_PORT=3012
JARVIS_MONITOR_PORT=3015

# =============================================================================
# Mission Control Integration
# =============================================================================
MISSION_CONTROL_URL=http://localhost:3002
MISSION_CONTROL_API_KEY=

# =============================================================================
# OpenClaw Integration
# =============================================================================
OPENCLAW_GATEWAY_URL=http://localhost:18789

# =============================================================================
# Feature Flags
# =============================================================================
FEATURE_ORB_MODE=true
FEATURE_SPHERE_MODE=true
FEATURE_WAVE_MODE=true
FEATURE_HUD_MODE=true
FEATURE_AMBIENT_MODE=true

# =============================================================================
# Conversation Intelligence (LLM) — Phase 5
# Kiaros is model-agnostic: the provider is selected here, never in code.
#   auto (default)     = anthropic if ANTHROPIC_API_KEY set, else
#                        openai-compatible if configured, else none
#   anthropic          = Anthropic API (conversation text leaves the machine)
#   openai-compatible  = any /v1/chat/completions runtime: Ollama, LM Studio,
#                        llama.cpp, vLLM, OpenAI, ... (localhost = fully local)
#   none               = built-in template responses only
# =============================================================================
KIAROS_LLM_PROVIDER=auto
# Generic model override (falls back to each provider's default)
KIAROS_LLM_MODEL=
KIAROS_LLM_MAX_TOKENS=1024
KIAROS_LLM_TIMEOUT_MS=30000

# Anthropic provider (default model: claude-opus-4-8)
ANTHROPIC_API_KEY=

# OpenAI-compatible provider (example: Ollama)
# OPENAI_COMPAT_BASE_URL=http://localhost:11434/v1
# OPENAI_COMPAT_MODEL=granite4.1:3b
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=info

# =============================================================================
# Memory
# =============================================================================
MEMORY_PATH=./memory
MEMORY_RETENTION_DAYS=30
